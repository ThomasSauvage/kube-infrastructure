
auto lo
iface lo inet loopback

# Public interface. No IP assigned as it's used by the bridge
auto {{ proxmox_node__public_interface }}
iface {{ proxmox_node__public_interface }} inet static

# Bridge for VMs
auto vmbr0
iface vmbr0 inet static
    address {{ proxmox_node__public_ipv4 }}{{ proxmox_node__public_ipv4_subnet }}
    gateway {{ proxmox_node__public_ipv4_gateway }}
    bridge-ports {{ proxmox_node__public_interface }}
    bridge-stp off
    bridge-fd 0
